generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  DIRECTOR
  SELLER
}

enum SaleType {
  CASH
  CREDIT
}

enum CashTransactionType {
  SALE_INCOME
  TRANSFER_IN
  TRANSFER_OUT
  EXPENSE
  MANUAL_IN
  MANUAL_OUT
  SALE_RETURN_OUT
  EXCHANGE_OUT
  EXCHANGE_IN
}

enum StockMovementType {
  SUPPLIER_IN
  SUPPLIER_RETURN
  TRANSFER_IN
  TRANSFER_OUT
  SALE_OUT
  CUSTOMER_RETURN
  INVENTORY_ADJUSTMENT
}

enum SupplierPaymentSource {
  CASHBOX
  OTHER
}

enum SupplierInStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WarehouseTransferStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InterStoreTransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  REJECTED
}

enum SupplierReturnStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CashboxTransferStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InterStoreCashTransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  REJECTED
}

enum CashExchangeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CashExchangeRateMode {
  MULTIPLY
  DIVIDE
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

model Store {
  id        String   @id @default(uuid())
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userStores                      UserStore[]
  warehouses                      Warehouse[]
  cashboxes                       Cashbox[]
  categories                      Category[]
  expenseCategories               ExpenseCategory[]
  products                        Product[]
  suppliers                       Supplier[]
  customers                       Customer[]
  sales                           Sale[]
  creditPayments                  CreditPayment[]
  saleReturns                     SaleReturn[]
  stockMovements                  StockMovement[]
  cashTransactions                CashTransaction[]
  expenses                        Expense[]
  inventoryCounts                 InventoryCount[]
  supplierLedgerEntries           SupplierLedgerEntry[]
  supplierPayments                SupplierPayment[]
  supplierIns                     SupplierIn[]
  warehouseTransfers              WarehouseTransfer[]
  supplierReturns                 SupplierReturn[]
  outgoingInterStoreCashTransfers InterStoreCashTransfer[] @relation("InterStoreCashTransferFromStore")
  incomingInterStoreCashTransfers InterStoreCashTransfer[] @relation("InterStoreCashTransferToStore")
  outgoingInterStoreTransfers     InterStoreTransfer[]     @relation("InterStoreTransferFromStore")
  incomingInterStoreTransfers     InterStoreTransfer[]     @relation("InterStoreTransferToStore")
  CashboxTransfer                 CashboxTransfer[]
  cashExchanges                   CashExchange[]
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  username     String   @unique
  passwordHash String
  role         Role     @default(SELLER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userStores                      UserStore[]
  sales                           Sale[]
  creditPayments                  CreditPayment[]
  cashTransactions                CashTransaction[]
  stockMovements                  StockMovement[]
  expenses                        Expense[]
  inventoryCounts                 InventoryCount[]
  supplierPayments                SupplierPayment[]
  submittedSupplierIns            SupplierIn[]             @relation("SupplierInSubmittedBy")
  approvedSupplierIns             SupplierIn[]             @relation("SupplierInApprovedBy")
  createdWarehouseTransfers       WarehouseTransfer[]      @relation("WarehouseTransferCreatedBy")
  approvedWarehouseTransfers      WarehouseTransfer[]      @relation("WarehouseTransferApprovedBy")
  submittedSupplierReturns        SupplierReturn[]         @relation("SupplierReturnSubmittedBy")
  approvedSupplierReturns         SupplierReturn[]         @relation("SupplierReturnApprovedBy")
  createdInterStoreTransfers      InterStoreTransfer[]     @relation("InterStoreTransferCreatedBy")
  sentInterStoreTransfers         InterStoreTransfer[]     @relation("InterStoreTransferSentBy")
  receivedInterStoreTransfers     InterStoreTransfer[]     @relation("InterStoreTransferReceivedBy")
  createdCashboxTransfers         CashboxTransfer[]        @relation("CashboxTransferCreatedBy")
  approvedCashboxTransfers        CashboxTransfer[]        @relation("CashboxTransferApprovedBy")
  rejectedCashboxTransfers        CashboxTransfer[]        @relation("CashboxTransferRejectedBy")
  createdInterStoreCashTransfers  InterStoreCashTransfer[] @relation("InterStoreCashTransferCreatedBy")
  sentInterStoreCashTransfers     InterStoreCashTransfer[] @relation("InterStoreCashTransferSentBy")
  receivedInterStoreCashTransfers InterStoreCashTransfer[] @relation("InterStoreCashTransferReceivedBy")
  createdCashExchanges            CashExchange[]           @relation("CashExchangeCreatedBy")
  approvedCashExchanges           CashExchange[]           @relation("CashExchangeApprovedBy")
  rejectedCashExchanges           CashExchange[]           @relation("CashExchangeRejectedBy")
  createdExpenses                 Expense[]                @relation("ExpenseCreatedBy")
  approvedExpenses                Expense[]                @relation("ExpenseApprovedBy")
  rejectedExpenses                Expense[]                @relation("ExpenseRejectedBy")
}

model UserStore {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

model Currency {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  symbol    String
  rate      Float    @default(1)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cashboxes                    Cashbox[]
  creditPayments               CreditPayment[]
  cashTransactions             CashTransaction[]
  stockBatchCostCurrencies     StockBatch[]             @relation("StockBatchCostCurrency")
  stockBatchSellCurrencies     StockBatch[]             @relation("StockBatchSellCurrency")
  supplierInItemCostCurrencies SupplierInItem[]         @relation("SupplierInItemCostCurrency")
  supplierInItemSellCurrencies SupplierInItem[]         @relation("SupplierInItemSellCurrency")
  saleItems                    SaleItem[]
  SupplierLedgerEntry          SupplierLedgerEntry[]
  SupplierPayment              SupplierPayment[]
  CashboxTransfer              CashboxTransfer[]
  interStoreCashTransfers      InterStoreCashTransfer[]
  cashExchangesFrom            CashExchange[]           @relation("CashExchangeFromCurrency")
  cashExchangesTo              CashExchange[]           @relation("CashExchangeToCurrency")
}

model Cashbox {
  id         String   @id @default(uuid())
  storeId    String
  currencyId String
  name       String
  balance    Float    @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  currency Currency @relation(fields: [currencyId], references: [id])

  sales                           Sale[]
  creditPayments                  CreditPayment[]
  saleReturns                     SaleReturn[]
  cashTransactions                CashTransaction[]
  expenses                        Expense[]
  supplierPayments                SupplierPayment[]
  transferFrom                    CashTransaction[]        @relation("TransferFromCashbox")
  transferTo                      CashTransaction[]        @relation("TransferToCashbox")
  outgoingTransfers               CashboxTransfer[]        @relation("CashboxTransferFromCashbox")
  incomingTransfers               CashboxTransfer[]        @relation("CashboxTransferToCashbox")
  outgoingInterStoreCashTransfers InterStoreCashTransfer[] @relation("InterStoreCashTransferFromCashbox")
  incomingInterStoreCashTransfers InterStoreCashTransfer[] @relation("InterStoreCashTransferToCashbox")
  outgoingExchanges               CashExchange[]           @relation("CashExchangeFromCashbox")
  incomingExchanges               CashExchange[]           @relation("CashExchangeToCashbox")

  @@unique([storeId, name])
}

model CashboxTransfer {
  id            String                @id @default(uuid())
  storeId       String
  fromCashboxId String
  toCashboxId   String
  currencyId    String
  amount        Decimal               @db.Decimal(18, 2)
  note          String?
  status        CashboxTransferStatus @default(PENDING)

  createdById  String
  approvedById String?
  rejectedById String?

  createdAt  DateTime  @default(now())
  approvedAt DateTime?
  rejectedAt DateTime?
  updatedAt  DateTime  @updatedAt

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  fromCashbox Cashbox  @relation("CashboxTransferFromCashbox", fields: [fromCashboxId], references: [id])
  toCashbox   Cashbox  @relation("CashboxTransferToCashbox", fields: [toCashboxId], references: [id])
  currency    Currency @relation(fields: [currencyId], references: [id])

  createdBy  User  @relation("CashboxTransferCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("CashboxTransferApprovedBy", fields: [approvedById], references: [id])
  rejectedBy User? @relation("CashboxTransferRejectedBy", fields: [rejectedById], references: [id])

  @@index([storeId, status, createdAt])
  @@index([fromCashboxId])
  @@index([toCashboxId])
}

model InterStoreCashTransfer {
  id String @id @default(uuid())

  fromStoreId   String
  toStoreId     String
  fromCashboxId String
  toCashboxId   String
  currencyId    String
  amount        Decimal                      @db.Decimal(18, 2)
  note          String?
  status        InterStoreCashTransferStatus @default(PENDING)

  createdById  String
  sentById     String?
  receivedById String?

  createdAt  DateTime  @default(now())
  sentAt     DateTime?
  receivedAt DateTime?
  updatedAt  DateTime  @updatedAt

  fromStore   Store    @relation("InterStoreCashTransferFromStore", fields: [fromStoreId], references: [id], onDelete: Cascade)
  toStore     Store    @relation("InterStoreCashTransferToStore", fields: [toStoreId], references: [id], onDelete: Cascade)
  fromCashbox Cashbox  @relation("InterStoreCashTransferFromCashbox", fields: [fromCashboxId], references: [id])
  toCashbox   Cashbox  @relation("InterStoreCashTransferToCashbox", fields: [toCashboxId], references: [id])
  currency    Currency @relation(fields: [currencyId], references: [id])

  createdBy  User  @relation("InterStoreCashTransferCreatedBy", fields: [createdById], references: [id])
  sentBy     User? @relation("InterStoreCashTransferSentBy", fields: [sentById], references: [id])
  receivedBy User? @relation("InterStoreCashTransferReceivedBy", fields: [receivedById], references: [id])

  @@index([fromStoreId, status, createdAt])
  @@index([toStoreId, status, createdAt])
  @@index([fromCashboxId])
  @@index([toCashboxId])
}

model CashTransaction {
  id               String              @id @default(uuid())
  storeId          String
  cashboxId        String
  currencyId       String
  createdById      String
  type             CashTransactionType
  amount           Float
  note             String?
  relatedSaleId    String?
  relatedExpenseId String?
  relatedReturnId  String?
  fromCashboxId    String?
  toCashboxId      String?
  createdAt        DateTime            @default(now())

  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashbox       Cashbox     @relation(fields: [cashboxId], references: [id], onDelete: Cascade)
  currency      Currency    @relation(fields: [currencyId], references: [id])
  createdBy     User        @relation(fields: [createdById], references: [id])
  relatedSale   Sale?       @relation(fields: [relatedSaleId], references: [id])
  relatedReturn SaleReturn? @relation(fields: [relatedReturnId], references: [id])
  fromCashbox   Cashbox?    @relation("TransferFromCashbox", fields: [fromCashboxId], references: [id])
  toCashbox     Cashbox?    @relation("TransferToCashbox", fields: [toCashboxId], references: [id])
}

model CashExchange {
  id             String @id @default(uuid())
  storeId        String
  fromCashboxId  String
  toCashboxId    String
  fromCurrencyId String
  toCurrencyId   String

  fromAmount   Decimal              @db.Decimal(18, 2)
  exchangeRate Decimal              @db.Decimal(18, 6)
  toAmount     Decimal              @db.Decimal(18, 2)
  rateMode     CashExchangeRateMode @default(MULTIPLY)

  note   String?
  status CashExchangeStatus @default(PENDING)

  createdById  String
  approvedById String?
  rejectedById String?

  createdAt  DateTime  @default(now())
  approvedAt DateTime?
  rejectedAt DateTime?
  updatedAt  DateTime  @updatedAt

  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  fromCashbox  Cashbox  @relation("CashExchangeFromCashbox", fields: [fromCashboxId], references: [id])
  toCashbox    Cashbox  @relation("CashExchangeToCashbox", fields: [toCashboxId], references: [id])
  fromCurrency Currency @relation("CashExchangeFromCurrency", fields: [fromCurrencyId], references: [id])
  toCurrency   Currency @relation("CashExchangeToCurrency", fields: [toCurrencyId], references: [id])

  createdBy  User  @relation("CashExchangeCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("CashExchangeApprovedBy", fields: [approvedById], references: [id])
  rejectedBy User? @relation("CashExchangeRejectedBy", fields: [rejectedById], references: [id])

  @@index([storeId, status, createdAt])
  @@index([fromCashboxId])
  @@index([toCashboxId])
}

model Warehouse {
  id        String   @id @default(uuid())
  storeId   String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store                  Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stockBatches           StockBatch[]
  stockMovements         StockMovement[]
  inventoryCounts        InventoryCount[]
  supplierIns            SupplierIn[]
  transferFrom           WarehouseTransfer[]  @relation("WarehouseTransferFrom")
  transferTo             WarehouseTransfer[]  @relation("WarehouseTransferTo")
  supplierReturns        SupplierReturn[]
  interStoreTransferFrom InterStoreTransfer[] @relation("InterStoreTransferFromWarehouse")
  interStoreTransferTo   InterStoreTransfer[] @relation("InterStoreTransferToWarehouse")

  @@unique([storeId, name])
}

model Supplier {
  id        String   @id @default(uuid())
  storeId   String
  name      String
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store           Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stockBatches    StockBatch[]
  ledgerEntries   SupplierLedgerEntry[]
  payments        SupplierPayment[]
  supplierIns     SupplierIn[]
  supplierReturns SupplierReturn[]

  @@unique([storeId, name])
}

model Customer {
  id        String   @id @default(uuid())
  storeId   String
  fullName  String
  phone     String?
  address   String?
  note      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sales          Sale[]
  creditPayments CreditPayment[]

  @@unique([storeId, fullName, phone])
  @@index([storeId])
  @@index([fullName])
  @@index([phone])
}

model SupplierLedgerEntry {
  id          String   @id @default(uuid())
  storeId     String
  supplierId  String
  currencyId  String
  totalAmount Float
  paidAmount  Float    @default(0)
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  currency Currency @relation(fields: [currencyId], references: [id])

  payments SupplierPayment[]

  @@index([storeId])
  @@index([supplierId])
  @@index([currencyId])
}

model SupplierPayment {
  id            String                @id @default(uuid())
  storeId       String
  supplierId    String
  ledgerEntryId String?
  cashboxId     String?
  createdById   String?
  source        SupplierPaymentSource
  currencyId    String
  amount        Float
  note          String?
  createdAt     DateTime              @default(now())

  store       Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  supplier    Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  ledgerEntry SupplierLedgerEntry? @relation(fields: [ledgerEntryId], references: [id])
  cashbox     Cashbox?             @relation(fields: [cashboxId], references: [id])
  createdBy   User?                @relation(fields: [createdById], references: [id])
  currency    Currency             @relation(fields: [currencyId], references: [id])

  @@index([storeId])
  @@index([supplierId])
  @@index([ledgerEntryId])
  @@index([currencyId])
}

model CreditPayment {
  id          String   @id @default(uuid())
  storeId     String
  customerId  String
  saleId      String?
  cashboxId   String
  currencyId  String
  createdById String
  amount      Float
  note        String?
  createdAt   DateTime @default(now())

  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sale      Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  cashbox   Cashbox  @relation(fields: [cashboxId], references: [id])
  currency  Currency @relation(fields: [currencyId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])

  @@index([storeId])
  @@index([customerId])
  @@index([saleId])
  @@index([cashboxId])
}

model Category {
  id        String   @id @default(uuid())
  storeId   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([storeId, name])
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  storeId   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([storeId, name])
}

model Size {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ProductVariant[]
}

model Product {
  id         String   @id @default(uuid())
  storeId    String
  categoryId String?
  name       String
  brand      String?
  gender     String?
  season     String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category?        @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  images   ProductImage[]

  @@index([storeId, name])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  imageUrl  String
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, isPrimary])
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  sizeId    String
  barcode   String?  @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size    Size    @relation(fields: [sizeId], references: [id])

  stockBatches           StockBatch[]
  stockMovements         StockMovement[]
  saleItems              SaleItem[]
  inventoryCountItems    InventoryCountItem[]
  supplierInItems        SupplierInItem[]
  warehouseTransferItems WarehouseTransferItem[]
  SupplierReturnItem     SupplierReturnItem[]
  InterStoreTransferItem InterStoreTransferItem[]

  @@unique([productId, sizeId])
  @@index([productId, sortOrder])
}

model WarehouseTransfer {
  id              String                  @id @default(uuid())
  storeId         String
  fromWarehouseId String
  toWarehouseId   String
  status          WarehouseTransferStatus @default(PENDING)
  note            String?
  createdById     String
  approvedById    String?
  createdAt       DateTime                @default(now())
  approvedAt      DateTime?
  updatedAt       DateTime                @updatedAt

  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse @relation("WarehouseTransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse @relation("WarehouseTransferTo", fields: [toWarehouseId], references: [id])
  createdBy     User      @relation("WarehouseTransferCreatedBy", fields: [createdById], references: [id])
  approvedBy    User?     @relation("WarehouseTransferApprovedBy", fields: [approvedById], references: [id])

  items WarehouseTransferItem[]

  @@index([storeId, status, createdAt])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([createdById])
  @@index([approvedById])
}

model WarehouseTransferItem {
  id               String   @id @default(uuid())
  transferId       String
  productVariantId String
  sourceBatchId    String
  quantity         Int
  createdAt        DateTime @default(now())

  transfer       WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productVariant ProductVariant    @relation(fields: [productVariantId], references: [id])
  sourceBatch    StockBatch        @relation(fields: [sourceBatchId], references: [id])

  @@index([transferId])
  @@index([productVariantId])
  @@index([sourceBatchId])
}

model InterStoreTransfer {
  id String @id @default(uuid())

  fromStoreId     String
  toStoreId       String
  fromWarehouseId String
  toWarehouseId   String

  status InterStoreTransferStatus @default(PENDING)
  note   String?

  createdById  String
  sentById     String?
  receivedById String?

  createdAt  DateTime  @default(now())
  sentAt     DateTime?
  receivedAt DateTime?
  updatedAt  DateTime  @updatedAt

  fromStore     Store     @relation("InterStoreTransferFromStore", fields: [fromStoreId], references: [id], onDelete: Cascade)
  toStore       Store     @relation("InterStoreTransferToStore", fields: [toStoreId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse @relation("InterStoreTransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse @relation("InterStoreTransferToWarehouse", fields: [toWarehouseId], references: [id])

  createdBy  User  @relation("InterStoreTransferCreatedBy", fields: [createdById], references: [id])
  sentBy     User? @relation("InterStoreTransferSentBy", fields: [sentById], references: [id])
  receivedBy User? @relation("InterStoreTransferReceivedBy", fields: [receivedById], references: [id])

  items InterStoreTransferItem[]

  @@index([fromStoreId, status, createdAt])
  @@index([toStoreId, status, createdAt])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

model InterStoreTransferItem {
  id               String   @id @default(uuid())
  transferId       String
  productVariantId String
  sourceBatchId    String
  quantity         Int
  createdAt        DateTime @default(now())

  transfer       InterStoreTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productVariant ProductVariant     @relation(fields: [productVariantId], references: [id])
  sourceBatch    StockBatch         @relation(fields: [sourceBatchId], references: [id])

  @@index([transferId])
  @@index([productVariantId])
  @@index([sourceBatchId])
}

model StockBatch {
  id                String  @id @default(uuid())
  warehouseId       String
  productVariantId  String
  supplierId        String?
  quantity          Int
  remainingQuantity Int

  costPrice      Float
  costCurrencyId String
  sellPrice      Float
  sellCurrencyId String

  createdAt DateTime @default(now())

  warehouse      Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  supplier       Supplier?      @relation(fields: [supplierId], references: [id])

  costCurrency Currency @relation("StockBatchCostCurrency", fields: [costCurrencyId], references: [id])
  sellCurrency Currency @relation("StockBatchSellCurrency", fields: [sellCurrencyId], references: [id])

  stockMovements         StockMovement[]
  saleItems              SaleItem[]
  warehouseTransferItems WarehouseTransferItem[]
  SupplierReturnItem     SupplierReturnItem[]
  InterStoreTransferItem InterStoreTransferItem[]

  @@index([costCurrencyId])
  @@index([sellCurrencyId])
}

model StockMovement {
  id               String            @id @default(uuid())
  storeId          String
  warehouseId      String
  productVariantId String
  batchId          String?
  createdById      String?
  type             StockMovementType
  quantity         Int
  note             String?
  createdAt        DateTime          @default(now())

  store          Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  warehouse      Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  batch          StockBatch?    @relation(fields: [batchId], references: [id])
  createdBy      User?          @relation(fields: [createdById], references: [id])
}

model SupplierIn {
  id            String           @id @default(uuid())
  storeId       String
  warehouseId   String
  supplierId    String
  submittedById String
  approvedById  String?
  status        SupplierInStatus @default(PENDING)
  note          String?
  createdAt     DateTime         @default(now())
  approvedAt    DateTime?

  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  supplier    Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  submittedBy User      @relation("SupplierInSubmittedBy", fields: [submittedById], references: [id])
  approvedBy  User?     @relation("SupplierInApprovedBy", fields: [approvedById], references: [id])

  items SupplierInItem[]
}

model SupplierInItem {
  id               String @id @default(uuid())
  supplierInId     String
  productVariantId String
  quantity         Int

  costPrice      Float
  costCurrencyId String
  sellPrice      Float
  sellCurrencyId String

  supplierIn     SupplierIn     @relation(fields: [supplierInId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  costCurrency Currency @relation("SupplierInItemCostCurrency", fields: [costCurrencyId], references: [id])
  sellCurrency Currency @relation("SupplierInItemSellCurrency", fields: [sellCurrencyId], references: [id])

  @@unique([supplierInId, productVariantId])
  @@index([costCurrencyId])
  @@index([sellCurrencyId])
}

model SupplierReturn {
  id            String               @id @default(uuid())
  storeId       String
  warehouseId   String
  supplierId    String
  submittedById String
  approvedById  String?
  status        SupplierReturnStatus @default(PENDING)
  note          String?
  createdAt     DateTime             @default(now())
  approvedAt    DateTime?

  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  supplier    Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  submittedBy User      @relation("SupplierReturnSubmittedBy", fields: [submittedById], references: [id])
  approvedBy  User?     @relation("SupplierReturnApprovedBy", fields: [approvedById], references: [id])

  items SupplierReturnItem[]
}

model SupplierReturnItem {
  id               String   @id @default(uuid())
  supplierReturnId String
  productVariantId String
  sourceBatchId    String
  quantity         Int
  createdAt        DateTime @default(now())

  supplierReturn SupplierReturn @relation(fields: [supplierReturnId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  sourceBatch    StockBatch     @relation(fields: [sourceBatchId], references: [id])

  @@index([supplierReturnId])
  @@index([productVariantId])
  @@index([sourceBatchId])
}

model Sale {
  id        String   @id @default(uuid())
  saleCode  String   @unique
  storeId   String
  cashboxId String
  sellerId  String
  type      SaleType @default(CASH)

  customerId      String?
  subtotalAmount  Float   @default(0)
  discountAmount  Float   @default(0)
  totalAmount     Float
  paidAmount      Float
  creditDueAmount Float   @default(0)

  customerName  String?
  customerPhone String?
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashbox  Cashbox   @relation(fields: [cashboxId], references: [id], onDelete: Cascade)
  seller   User      @relation(fields: [sellerId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  items           SaleItem[]
  creditPayments  CreditPayment[]
  returns         SaleReturn[]
  CashTransaction CashTransaction[]

  @@index([storeId, type])
  @@index([customerId])
}

model SaleItem {
  id               String  @id @default(uuid())
  saleId           String
  productVariantId String
  batchId          String?
  currencyId       String
  quantity         Int

  unitPrice      Float
  discountAmount Float @default(0)
  totalPrice     Float

  createdAt DateTime @default(now())

  sale           Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  batch          StockBatch?    @relation(fields: [batchId], references: [id])
  currency       Currency       @relation(fields: [currencyId], references: [id])

  returnItems SaleReturnItem[]

  @@index([currencyId])
}

model SaleReturn {
  id        String   @id @default(uuid())
  saleId    String
  storeId   String
  cashboxId String?
  amount    Float
  reason    String?
  createdAt DateTime @default(now())

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  store   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashbox Cashbox? @relation(fields: [cashboxId], references: [id])

  items           SaleReturnItem[]
  CashTransaction CashTransaction[]
}

model SaleReturnItem {
  id           String @id @default(uuid())
  saleReturnId String
  saleItemId   String
  quantity     Int
  amount       Float

  saleReturn SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  saleItem   SaleItem   @relation(fields: [saleItemId], references: [id])

  @@unique([saleReturnId, saleItemId])
}

model Expense {
  id                String        @id @default(uuid())
  storeId           String
  cashboxId         String
  expenseCategoryId String?
  createdById       String?
  approvedById      String?
  rejectedById      String?
  amount            Float
  note              String?
  status            ExpenseStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  approvedAt        DateTime?
  rejectedAt        DateTime?
  updatedAt         DateTime      @updatedAt

  store           Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashbox         Cashbox          @relation(fields: [cashboxId], references: [id], onDelete: Cascade)
  expenseCategory ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])
  createdBy       User?            @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  approvedBy      User?            @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  rejectedBy      User?            @relation("ExpenseRejectedBy", fields: [rejectedById], references: [id])
  User            User?            @relation(fields: [userId], references: [id])
  userId          String?

  @@index([storeId, status, createdAt])
  @@index([cashboxId])
}

model InventoryCount {
  id          String   @id @default(uuid())
  storeId     String
  warehouseId String
  createdById String?
  note        String?
  createdAt   DateTime @default(now())

  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id])

  items InventoryCountItem[]
}

model InventoryCountItem {
  id               String @id @default(uuid())
  inventoryCountId String
  productVariantId String
  systemQuantity   Int
  countedQuantity  Int

  inventoryCount InventoryCount @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@unique([inventoryCountId, productVariantId])
}
