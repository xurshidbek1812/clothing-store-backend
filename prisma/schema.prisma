generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DIRECTOR
  SELLER
}

enum SaleType {
  CASH
  CREDIT
}

enum CashTransactionType {
  SALE_INCOME
  TRANSFER_IN
  TRANSFER_OUT
  EXPENSE
  MANUAL_IN
  MANUAL_OUT
}

enum StockMovementType {
  SUPPLIER_IN
  SUPPLIER_RETURN
  TRANSFER_IN
  TRANSFER_OUT
  SALE_OUT
  CUSTOMER_RETURN
  INVENTORY_ADJUSTMENT
}

model Store {
  id         String   @id @default(uuid())
  name       String
  address    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userStores         UserStore[]
  warehouses         Warehouse[]
  cashboxes          Cashbox[]
  categories         Category[]
  expenseCategories  ExpenseCategory[]
  products           Product[]
  suppliers          Supplier[]
  sales              Sale[]
  stockMovements     StockMovement[]
  cashTransactions   CashTransaction[]
  expenses           Expense[]
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  username     String   @unique
  passwordHash String
  role         Role     @default(SELLER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userStores        UserStore[]
  sales             Sale[]
  cashTransactions  CashTransaction[]
  stockMovements    StockMovement[]
  expenses          Expense[]
  inventoryCounts   InventoryCount[]
}

model UserStore {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

model Currency {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  symbol      String
  rate        Float    @default(1)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cashboxes         Cashbox[]
  cashTransactions  CashTransaction[]
}

model Cashbox {
  id          String   @id @default(uuid())
  storeId     String
  currencyId  String
  name        String
  balance     Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  currency   Currency @relation(fields: [currencyId], references: [id])

  sales              Sale[]
  cashTransactions   CashTransaction[]
  expenses           Expense[]
  transferFrom       CashTransaction[] @relation("TransferFromCashbox")
  transferTo         CashTransaction[] @relation("TransferToCashbox")
}

model CashTransaction {
  id               String              @id @default(uuid())
  storeId          String
  cashboxId        String
  currencyId       String
  createdById      String
  type             CashTransactionType
  amount           Float
  note             String?
  relatedSaleId    String?
  relatedExpenseId String?
  fromCashboxId    String?
  toCashboxId      String?
  createdAt        DateTime            @default(now())

  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashbox      Cashbox   @relation(fields: [cashboxId], references: [id], onDelete: Cascade)
  currency     Currency  @relation(fields: [currencyId], references: [id])
  createdBy    User      @relation(fields: [createdById], references: [id])

  relatedSale  Sale?     @relation(fields: [relatedSaleId], references: [id])
  fromCashbox  Cashbox?  @relation("TransferFromCashbox", fields: [fromCashboxId], references: [id])
  toCashbox    Cashbox?  @relation("TransferToCashbox", fields: [toCashboxId], references: [id])
}

model Warehouse {
  id         String   @id @default(uuid())
  storeId    String
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stockBatches    StockBatch[]
  stockMovements  StockMovement[]
  inventoryCounts InventoryCount[]
}

model Supplier {
  id         String   @id @default(uuid())
  storeId    String
  name       String
  phone      String?
  address    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stockBatches StockBatch[]
}

model Category {
  id         String   @id @default(uuid())
  storeId    String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([storeId, name])
}

model ExpenseCategory {
  id         String   @id @default(uuid())
  storeId    String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  expenses  Expense[]

  @@unique([storeId, name])
}

model Size {
  id         String   @id @default(uuid())
  name       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  variants   ProductVariant[]
}

model Product {
  id          String   @id @default(uuid())
  storeId     String
  categoryId  String?
  name        String
  brand       String?
  gender      String?
  season      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category   Category?  @relation(fields: [categoryId], references: [id])

  variants   ProductVariant[]
}

model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  sizeId      String
  barcode     String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  size         Size            @relation(fields: [sizeId], references: [id])

  stockBatches   StockBatch[]
  stockMovements StockMovement[]
  saleItems      SaleItem[]

  @@unique([productId, sizeId])
}

model StockBatch {
  id                String   @id @default(uuid())
  warehouseId       String
  productVariantId  String
  supplierId        String?
  quantity          Int
  remainingQuantity Int
  costPrice         Float
  sellPrice         Float
  createdAt         DateTime @default(now())

  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productVariant  ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  supplier        Supplier?      @relation(fields: [supplierId], references: [id])

  stockMovements  StockMovement[]
  saleItems       SaleItem[]
}

model StockMovement {
  id                String            @id @default(uuid())
  storeId           String
  warehouseId       String
  productVariantId  String
  batchId           String?
  createdById       String?
  type              StockMovementType
  quantity          Int
  note              String?
  createdAt         DateTime          @default(now())

  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productVariant  ProductVariant  @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  batch           StockBatch?     @relation(fields: [batchId], references: [id])
  createdBy       User?           @relation(fields: [createdById], references: [id])
}

model Sale {
  id             String    @id @default(uuid())
  storeId        String
  cashboxId      String
  sellerId       String
  type           SaleType  @default(CASH)
  totalAmount    Float
  paidAmount     Float
  customerName   String?
  customerPhone  String?
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  store         Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashbox       Cashbox    @relation(fields: [cashboxId], references: [id], onDelete: Cascade)
  seller        User       @relation(fields: [sellerId], references: [id])

  items         SaleItem[]
  cashTransactions CashTransaction[]
  returns       SaleReturn[]
}

model SaleItem {
  id                String   @id @default(uuid())
  saleId            String
  productVariantId  String
  batchId           String?
  quantity          Int
  price             Float
  createdAt         DateTime @default(now())

  sale             Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant  @relation(fields: [productVariantId], references: [id])
  batch            StockBatch?     @relation(fields: [batchId], references: [id])

  returnItems      SaleReturnItem[]
}

model SaleReturn {
  id          String   @id @default(uuid())
  saleId      String
  storeId     String
  cashboxId   String?
  amount      Float
  reason      String?
  createdAt   DateTime @default(now())

  sale        Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashbox     Cashbox?  @relation(fields: [cashboxId], references: [id])

  items       SaleReturnItem[]
}

model Expense {
  id                String   @id @default(uuid())
  storeId           String
  cashboxId         String
  expenseCategoryId String?
  createdById       String?
  amount            Float
  note              String?
  createdAt         DateTime @default(now())

  store             Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashbox           Cashbox          @relation(fields: [cashboxId], references: [id], onDelete: Cascade)
  expenseCategory   ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])
  createdBy         User?            @relation(fields: [createdById], references: [id])
}

model InventoryCount {
  id           String   @id @default(uuid())
  storeId      String
  warehouseId  String
  createdById  String?
  note         String?
  createdAt    DateTime @default(now())

  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy    User?    @relation(fields: [createdById], references: [id])

  items        InventoryCountItem[]
}

model InventoryCountItem {
  id               String   @id @default(uuid())
  inventoryCountId String
  productVariantId String
  systemQuantity   Int
  countedQuantity  Int

  inventoryCount   InventoryCount @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@unique([inventoryCountId, productVariantId])
}

model SaleReturnItem {
  id           String   @id @default(uuid())
  saleReturnId String
  saleItemId   String
  quantity     Int
  amount       Float

  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  saleItem     SaleItem   @relation(fields: [saleItemId], references: [id])

  @@unique([saleReturnId, saleItemId])
}